# Copy to .env and fill in. Never commit the real .env (already gitignored).

# Qualcomm AI Hub — export/quantize/profile models for the Hexagon NPU.
# Get a token at https://app.aihub.qualcomm.com
AI_HUB_API_TOKEN=

# Sarvam Task Engine — online NL -> task-graph planning.
# Leave unset to always use the on-device FunctionGemma fallback.
SARVAM_API_KEY=

# Optional: Hugging Face token, if pulling gated model weights.
HF_TOKEN=
